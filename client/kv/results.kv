<ResultsScreen>:
    main_layout: main_layout
    table_container: table_container
    
    BoxLayout:
        id: main_layout
        orientation: "vertical"
        padding: 10
        spacing: 10
        
        # Верхняя панель с кнопками
        BoxLayout:
            id: top_panel
            orientation: "horizontal"
            size_hint: (1, 0.08)
            spacing: 10
            padding: (0, 5)
            
            Button:
                text: "Обновить"
                size_hint: (0.2, 1)
                background_color: (0.3, 0.5, 0.7, 1)
                on_release: root.refresh_results()
                
            Button:
                text: "Экспорт в Excel"
                size_hint: (0.2, 1)
                background_color: (0.2, 0.7, 0.3, 1)
                on_release: root.show_export_dialog()
                
            Button:
                text: "Статистика"
                size_hint: (0.2, 1)
                background_color: (0.7, 0.5, 0.2, 1)
                on_release: root.show_statistics()
                
            Button:
                text: "Назад"
                size_hint: (0.2, 1)
                background_color: (0.7, 0.3, 0.3, 1)
                on_release: root.go_to_menu()
        
        # Контейнер для таблицы
        BoxLayout:
            id: table_container
            orientation: "vertical"
            size_hint: (1, 0.92)
