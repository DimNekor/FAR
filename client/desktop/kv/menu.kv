<MenuScreen>:
    name: 'menu'
    
    BoxLayout:
        orientation: 'vertical'
        padding: [50, 80]
        spacing: 30
        size_hint: 0.75, 0.85
        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
        
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.35
            spacing: 8
            
            Label:
                text: 'FAR'
                font_size: 64
                bold: True
                color: 0.9, 0.95, 1, 1
                size_hint_y: 0.5
                halign: 'center'
                valign: 'bottom'
            
            Label:
                text: 'Fitness Aftereffect on Recognition'
                font_size: 18
                color: 0.5, 0.75, 0.95, 0.9
                size_hint_y: 0.25
                halign: 'center'
            
            Label:
                text: 'Neurocognitive Research Platform'
                font_size: 16
                color: 0.4, 0.6, 0.8, 0.7
                size_hint_y: 0.25
                halign: 'center'
        
        Widget:
            size_hint_y: 0.05
        
        Button:
            id: btn_survey
            text: 'НАЧАТЬ ИССЛЕДОВАНИЕ'
            size_hint: 0.85, None
            height: 70
            pos_hint: {'center_x': 0.5}
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 1, 1, 1, 1
            font_size: 22
            bold: True
            on_release: root.go_to_survey()
            
            canvas.before:
                # Тень
                Color:
                    rgba: 0, 0, 0, 0.3
                RoundedRectangle:
                    pos: self.x - 2, self.y - 2
                    size: self.width + 4, self.height + 4
                    radius: [35]
                
                # Основной фон кнопки
                Color:
                    rgba: 0.15, 0.55, 0.8, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [35]
                
                # Блик сверху
                Color:
                    rgba: 1, 1, 1, 0.15
                RoundedRectangle:
                    pos: self.x + 5, self.y + self.height/2
                    size: self.width - 10, self.height/2 - 2
                    radius: [0, 0, 30, 30]
            
            on_press: 
                self.background_color = (0.08, 0.35, 0.55, 1)
                self.color = (0.9, 0.9, 1, 1)
            on_release: 
                self.background_color = (0, 0, 0, 0)
                self.color = (1, 1, 1, 1)
        
        Button:
            id: btn_results
            text: 'ПОСМОТРЕТЬ РЕЗУЛЬТАТЫ'
            size_hint: 0.85, None
            height: 65
            pos_hint: {'center_x': 0.5}
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.9, 0.95, 1, 1
            font_size: 20
            bold: True
            on_release: root.go_to_results()
            
            canvas.before:
                # Тень
                Color:
                    rgba: 0, 0, 0, 0.3
                RoundedRectangle:
                    pos: self.x - 2, self.y - 2
                    size: self.width + 4, self.height + 4
                    radius: [32]
                
                # Основной фон
                Color:
                    rgba: 0.25, 0.5, 0.7, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [32]
                
                # Блик сверху
                Color:
                    rgba: 1, 1, 1, 0.12
                RoundedRectangle:
                    pos: self.x + 5, self.y + self.height/2
                    size: self.width - 10, self.height/2 - 2
                    radius: [0, 0, 28, 28]
            
            on_press: 
                self.background_color = (0.15, 0.3, 0.48, 1)
                self.color = (0.8, 0.85, 1, 1)
            on_release: 
                self.background_color = (0, 0, 0, 0)
                self.color = (0.9, 0.95, 1, 1)
        
        Button:
            id: btn_settings
            text: 'НАСТРОЙКИ'
            size_hint: 0.85, None
            height: 60
            pos_hint: {'center_x': 0.5}
            background_normal: ''
            background_color: 0, 0, 0, 0
            color: 0.8, 0.85, 0.95, 1
            font_size: 18
            bold: True
            on_release: root.go_to_settings()
            
            canvas.before:
                # Тень
                Color:
                    rgba: 0, 0, 0, 0.3
                RoundedRectangle:
                    pos: self.x - 2, self.y - 2
                    size: self.width + 4, self.height + 4
                    radius: [30]
                
                # Основной фон
                Color:
                    rgba: 0.33, 0.43, 0.6, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [30]
                
                # Блик сверху
                Color:
                    rgba: 1, 1, 1, 0.1
                RoundedRectangle:
                    pos: self.x + 5, self.y + self.height/2
                    size: self.width - 10, self.height/2 - 2
                    radius: [0, 0, 26, 26]
            
            on_press: 
                self.background_color = (0.22, 0.28, 0.4, 1)
                self.color = (0.7, 0.75, 0.9, 1)
            on_release: 
                self.background_color = (0, 0, 0, 0)
                self.color = (0.8, 0.85, 0.95, 1)
        
        Widget:
            size_hint_y: 0.1
